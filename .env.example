# Root-level env var reference for Flume.
# Copy relevant sections into service/.env and the Xcode xcconfig file.
# Never commit real values.

# ── Railway service (see service/.env.example for details) ───────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RAILWAY_PUBLIC_DOMAIN=

# ── SwiftUI client (Xcode xcconfig / Info.plist) ─────────────────────────────
SUPABASE_ANON_KEY=
RAILWAY_SERVICE_URL=
