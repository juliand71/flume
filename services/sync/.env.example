# Railway service environment variables
# Copy to service/.env for local development (never commit .env)

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox           # sandbox | production

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=  # service role — never expose to the client

RAILWAY_PUBLIC_DOMAIN=      # set automatically by Railway in production
